generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  phone          String?
  hashedPassword String
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
}

model Category {
  id        String    @id
  name      String
  tagline   String
  image     String
  accent    String
  sortOrder Int       @default(0)
  products  Product[]
}

model Product {
  id            String   @id
  name          String
  brand         String
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  price         Float
  originalPrice Float?
  rating        Float    @default(0)
  reviews       Int      @default(0)
  description   String
  features      String[]
  images        String[]
  badge         String?
  stock         Int      @default(0)
  unit          String?
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@index([featured])
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  items           String
  subtotal        Float
  shipping        Float
  tax             Float
  total           Float
  status          String   @default("placed")
  razorpayOrderId String?
  razorpayPayId   String?
  address         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
